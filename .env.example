# OpenAI API key for AI Assistant
OPENAI_API_KEY=sk-...

# MySQL database connection
DATABASE_URL=mysql://user:pass@localhost:3306/db_name
SHADOW_DATABASE_URL=mysql://user:pass@localhost:3306/db_name_shadow

# JWT secret for access/refresh tokens
SECRET_KEY=jwt-secret-key

# DevExtreme license key
NEXT_PUBLIC_DEVEXTREME_KEY="dx_key_here"

# Email (SMTP) configuration for password reset
EMAIL_HOST=mail.example.com
EMAIL_PORT=465
EMAIL_USER=info@example.com
EMAIL_PASS=your-email-password
